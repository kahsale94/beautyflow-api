    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  for (const [key, value] of Object.entries(item.json)) {\n    if (!value) continue;\n\n    const service = JSON.parse(value);\n\n    output.push({\n      json: {\n        id: service.id,\n        name: service.name,\n        price: service.price,\n        duration_minutes: service.duration_minutes,\n      },\n    });\n  }\n}\n\nreturn output;"
      },

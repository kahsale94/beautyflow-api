    {
      "parameters": {
        "jsCode": "const httpItems = $('get all').all();\nconst redisItems = $('get context').all();\n\nconst redisIds = new Set();\n\nfor (const item of redisItems) {\n  for (const value of Object.values(item.json)) {\n    const service = JSON.parse(value);\n    redisIds.add(String(service.id));\n  }\n}\n\nreturn httpItems\n  .filter(item => !redisIds.has(String(item.json.id)))\n  .map(item => ({\n    json: {\n      id: item.json.id,\n      name: item.json.name,\n      price: item.json.price,\n      duration_minutes: item.json.duration_minutes,\n    },\n  }));"
      },

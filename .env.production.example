ENVIRONMENT=production

POSTGRES_USER=beautyflow
POSTGRES_PASSWORD=replace-with-a-strong-random-password
POSTGRES_DB=beautyflow
DATABASE_URL=postgresql+psycopg://beautyflow:replace-with-a-strong-random-password@db-postgres:5432/beautyflow

REDIS_PASSWORD=replace-with-a-strong-random-password

ALGORITHM=HS256
USER_SECRET_KEY=replace-with-at-least-32-random-characters
INTEGRATION_SECRET_KEY=replace-with-at-least-32-random-characters
BUSINESS_INTEGRATION_SECRET_KEY=replace-with-at-least-32-random-characters

USER_ACCESS_TOKEN_EXPIRE_MINUTES=30
USER_REFRESH_TOKEN_EXPIRE_DAYS=7
INTEGRATION_TOKEN_EXPIRE_DAYS=30
BUSINESS_INTEGRATION_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=https://admin.example.com
FORWARDED_ALLOW_IPS=replace-with-reverse-proxy-ip
TRUSTED_PROXY_IPS=replace-with-reverse-proxy-ip

USER_REFRESH_COOKIE_SECURE=true
ADMIN_COOKIE_SECURE=true

N8N_ERROR_WEBHOOK_URL=https://n8n.example.com/webhook/beautyflow-error
N8N_WEBHOOK_HEADER=X-Beautyflow-Webhook-Secret
N8N_WEBHOOK_SECRET=replace-with-a-strong-random-secret

EVOLUTION_API_URL=https://evolution.example.com
EVOLUTION_API_KEY=replace-with-the-global-evolution-api-key
EVOLUTION_WEBHOOK_URL=https://n8n.example.com/webhook/beauty-api
EVOLUTION_INSTANCE_PREFIX=beautyflow-production
EVOLUTION_REQUEST_TIMEOUT_SECONDS=15

BEAUTYFLOW_EXTERNAL_NETWORK=n8n-network
LOG_LEVEL=INFO
TZ=America/Sao_Paulo
